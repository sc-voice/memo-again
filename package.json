{
  "name": "memo-again",
  "version": "0.11.0",
  "description": "Serializable memoizer with promises",
  "main": "index.js",
  "directories": {
    "src": "src",
    "test": "test"
  },
  "dependencies": {
    "log-instance": "^1.9.0",
